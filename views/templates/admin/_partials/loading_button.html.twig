{#
    Loading Button Partial

    Usage:
    {% include '@Modules/sc_verify_multishop/views/templates/admin/_partials/loading_button.html.twig' with {
        label: 'Apply Fix',
        loading_label: 'Processing...',
        icon: 'build',
        type: 'primary',
        form_id: 'my-form',
        confirm_message: 'Are you sure?'
    } %}

    Parameters:
    - label: Button text (required)
    - loading_label: Text shown during loading (default: 'Loading...')
    - icon: Material icon name (default: 'build')
    - type: Button type - primary, secondary, danger, etc. (default: 'primary')
    - form_id: Form ID for the submit handler (required)
    - btn_id: Button ID (default: form_id ~ '-btn')
    - disabled: Whether button is disabled (default: false)
    - confirm_message: If set, shows a confirm dialog before submitting (optional)
#}

{% set btn_id = btn_id|default(form_id ~ '-btn') %}

<button type="submit" class="btn btn-{{ type|default('primary') }}{% if disabled|default(false) %} disabled{% endif %}" id="{{ btn_id }}"{% if disabled|default(false) %} disabled{% endif %}>
    <span class="btn-text">
        <i class="material-icons">{{ icon|default('build') }}</i>
        {{ label|trans({}, 'Modules.Scverifymultishop.Admin') }}
    </span>
    <span class="btn-loading d-none">
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        {{ (loading_label|default('Loading...'))|trans({}, 'Modules.Scverifymultishop.Admin') }}
    </span>
</button>

<script>
(function() {
    var form = document.getElementById('{{ form_id }}');
    var btn = document.getElementById('{{ btn_id }}');
    if (form && btn) {
        form.addEventListener('submit', function(e) {
            {% if confirm_message is defined and confirm_message %}
            if (!confirm('{{ confirm_message|trans({}, 'Modules.Scverifymultishop.Admin')|e('js') }}')) {
                e.preventDefault();
                return false;
            }
            {% endif %}
            btn.querySelector('.btn-text').classList.add('d-none');
            btn.querySelector('.btn-loading').classList.remove('d-none');
            btn.disabled = true;
            btn.classList.add('disabled');
        });
    }
})();
</script>

{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
{% include '@Modules/sc_verify_multishop/views/templates/admin/_partials/header_tabs.html.twig' with {current_tab: 'dashboard', current_title: 'Diagnostic: ' ~ type} %}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-header-title">
                    <i class="material-icons">analytics</i>
                    {{ 'Diagnostic: %type%'|trans({'%type%': type}, 'Modules.Scverifymultishop.Admin') }}
                </h3>
                {% if result.status is defined %}
                <span class="badge badge-{{ result.status == 'ok' ? 'success' : (result.status == 'warning' ? 'warning' : 'danger') }}">
                    {{ result.status|upper }}
                </span>
                {% endif %}
            </div>
            <div class="card-body">
                <a href="{{ path('sc_verify_multishop_dashboard') }}" class="btn btn-outline-secondary mb-3">
                    <i class="material-icons">arrow_back</i>
                    {{ 'Back to Dashboard'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                </a>

                {% if result.error is defined %}
                <div class="alert alert-danger">
                    {{ result.error }}
                </div>
                {% else %}
                    {# Display diagnostic results based on type #}
                    {% if type == 'shops' and result.shops is defined %}
                        <h4>{{ 'Shops Configuration'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>{{ 'Name'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Active'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for shop in result.shops %}
                                <tr>
                                    <td>{{ shop.id_shop }}</td>
                                    <td>{{ shop.name }}</td>
                                    <td>
                                        {% if shop.active %}
                                            <span class="badge badge-success">Active</span>
                                        {% else %}
                                            <span class="badge badge-danger">Inactive</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>

                    {% elseif type == 'payments' and result.modules is defined %}
                        <h4>{{ 'Payment Modules'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>{{ 'Name'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Active'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Shops'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Carriers'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Issues'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for module in result.modules %}
                                <tr>
                                    <td>{{ module.id_module }}</td>
                                    <td>{{ module.name }}</td>
                                    <td>
                                        {% if module.active %}
                                            <span class="badge badge-success">Active</span>
                                        {% else %}
                                            <span class="badge badge-danger">Inactive</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ module.shops_count }}/{{ result.total_shops }}</td>
                                    <td>{{ module.carriers_count }}</td>
                                    <td>
                                        {% for issue in module.issues %}
                                            <span class="badge badge-{{ issue.severity == 'error' ? 'danger' : 'warning' }}">
                                                {{ issue.message }}
                                            </span>
                                        {% else %}
                                            <span class="badge badge-success">OK</span>
                                        {% endfor %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>

                    {% elseif type == 'carriers' and result.carriers is defined %}
                        <h4>{{ 'Carriers'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>{{ 'Name'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Active'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Shops'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Zones'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Delivery'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Issues'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for carrier in result.carriers %}
                                <tr>
                                    <td>{{ carrier.id_carrier }}</td>
                                    <td>{{ carrier.name }}</td>
                                    <td>
                                        {% if carrier.active %}
                                            <span class="badge badge-success">Active</span>
                                        {% else %}
                                            <span class="badge badge-secondary">Inactive</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ carrier.shops_count }}/{{ result.total_shops }}</td>
                                    <td>{{ carrier.zones_count }}</td>
                                    <td>{{ carrier.delivery_count }}</td>
                                    <td>
                                        {% for issue in carrier.issues %}
                                            <span class="badge badge-{{ issue.severity == 'error' ? 'danger' : 'warning' }}">
                                                {{ issue.message }}
                                            </span>
                                        {% else %}
                                            {% if carrier.active %}
                                                <span class="badge badge-success">OK</span>
                                            {% endif %}
                                        {% endfor %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>

                    {% elseif type == 'stocks' %}
                        <h4>{{ 'Stocks Analysis'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>

                        {# Share stock configuration indicator #}
                        <div class="mb-3">
                            <span class="badge badge-{{ result.share_stock ? 'info' : 'secondary' }}" style="font-size: 0.9rem;">
                                <i class="material-icons" style="font-size: 14px; vertical-align: middle;">{{ result.share_stock ? 'link' : 'link_off' }}</i>
                                {{ result.share_stock ? 'Stock partagé activé' : 'Stock partagé désactivé' }}
                                ({{ result.share_stock_group }})
                            </span>
                            {% if result.share_stock %}
                            <small class="text-muted d-block mt-1">
                                <i class="material-icons" style="font-size: 12px; vertical-align: middle;">info</i>
                                Les stocks doivent être dans id_shop = 0 (global)
                            </small>
                            {% endif %}
                        </div>

                        <div class="alert alert-{{ result.diagnostic_type == 'ok' ? 'success' : (result.diagnostic_type == 'warning' ? 'warning' : 'danger') }}">
                            {{ result.diagnostic }}
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Total Entries'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>{{ result.count_total }}</h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Shop 1 Entries'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>{{ result.count_shop1 }}</h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Global Entries'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>{{ result.count_global }}</h2>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {% if result.shop_distribution is defined %}
                        <h5>{{ 'Distribution by Shop'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>{{ 'Shop ID'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Count'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Total Qty'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Unique Products'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'NULL Quantities'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for dist in result.shop_distribution %}
                                <tr>
                                    <td>{{ dist.id_shop }}</td>
                                    <td>{{ dist.count }}</td>
                                    <td>{{ dist.total_quantity }}</td>
                                    <td>{{ dist.unique_products }}</td>
                                    <td>
                                        {% if dist.null_quantities > 0 %}
                                            <span class="badge badge-warning">{{ dist.null_quantities }}</span>
                                        {% else %}
                                            0
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% endif %}

                        {# Fix buttons for stock issues #}
                        {% if result.share_stock and result.count_shop1|default(0) > 0 %}
                        <div class="d-flex justify-content-end mt-4">
                            <a href="{{ path('sc_verify_multishop_fix_preview', {type: 'stocks'}) }}" class="btn btn-primary">
                                <i class="material-icons">build</i>
                                {{ 'Fix Stocks (id_shop 1→0)'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </a>
                        </div>
                        {% endif %}

                    {% elseif type == 'products' %}
                        <h4>{{ 'Multishop Products Validation'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>
                        <p class="text-muted mb-3">
                            {{ result.total_shops }} boutiques actives, {{ result.total_langs }} langues
                            <span class="ms-2">|</span>
                            <span class="ms-2">Source: Shop {{ result.source_shop }}</span>
                        </p>

                        {# Summary cards #}
                        <div class="row mb-4">
                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Total Products'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>{{ result.total_products }}</h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Total Missing'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2 class="{{ result.total_missing > 0 ? 'text-danger' : 'text-success' }}">
                                            {{ result.total_missing }}
                                        </h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Status'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>
                                            {% if result.status == 'ok' %}
                                                <span class="badge badge-success" style="font-size: 1.2rem;">OK</span>
                                            {% elseif result.status == 'warning' %}
                                                <span class="badge badge-warning" style="font-size: 1.2rem;">WARNING</span>
                                            {% else %}
                                                <span class="badge badge-danger" style="font-size: 1.2rem;">ERROR</span>
                                            {% endif %}
                                        </h2>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Detailed steps table #}
                        {% if result.steps is defined and result.steps|length > 0 %}
                        <h5 class="mt-4">{{ 'Data Analysis'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                        <table class="table table-striped">
                            <thead class="thead-light">
                                <tr>
                                    <th>{{ 'Table'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Description'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-center">{{ 'Total'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-center">{{ 'Missing'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-center">{{ 'Status'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for step in result.steps %}
                                <tr>
                                    <td><code>{{ step.table }}</code></td>
                                    <td>
                                        {{ step.label }}
                                        {% if step.detail is defined and step.detail %}
                                            <br><small class="text-muted">{{ step.detail }}</small>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">{{ step.total }}</td>
                                    <td class="text-center">
                                        {% if step.missing > 0 %}
                                            <span class="text-danger fw-bold">{{ step.missing }}</span>
                                        {% else %}
                                            <span class="text-success">0</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if step.status == 'ok' %}
                                            <span class="badge badge-success">OK</span>
                                        {% elseif step.status == 'warning' %}
                                            <span class="badge badge-warning">{{ step.missing }} à corriger</span>
                                        {% else %}
                                            <span class="badge badge-danger">{{ step.missing }} à corriger</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% endif %}

                        {# Fix button - only show if there are issues to fix #}
                        {% if result.total_missing > 0 %}
                        <div class="d-flex justify-content-end mt-4">
                            <a href="{{ path('sc_verify_multishop_fix_preview', {type: 'products'}) }}" class="btn btn-primary">
                                <i class="material-icons">build</i>
                                {{ 'Fix Product Associations'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </a>
                        </div>
                        {% else %}
                        <div class="alert alert-success mt-4">
                            <i class="material-icons">check_circle</i>
                            {{ 'All products are correctly configured for all shops.'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                        </div>
                        {% endif %}

                    {% elseif type == 'shop_group' %}
                        <h4>{{ 'Shop Group Configuration'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>
                        {% if result.all_shares_enabled is defined %}
                        <div class="alert alert-{{ result.all_shares_enabled ? 'success' : 'warning' }}">
                            {% if result.all_shares_enabled %}
                                {{ 'All sharing options are enabled.'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            {% else %}
                                {{ 'Some sharing options are not enabled.'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            {% endif %}
                        </div>
                        {% endif %}

                        {% if result.shop_groups is defined %}
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>{{ 'Name'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Share Customers'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Share Orders'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Share Stock'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for group in result.shop_groups %}
                                <tr>
                                    <td>{{ group.id_shop_group }}</td>
                                    <td>{{ group.name }}</td>
                                    <td><span class="badge badge-{{ group.share_customer ? 'success' : 'danger' }}">{{ group.share_customer ? 'Yes' : 'No' }}</span></td>
                                    <td><span class="badge badge-{{ group.share_order ? 'success' : 'danger' }}">{{ group.share_order ? 'Yes' : 'No' }}</span></td>
                                    <td><span class="badge badge-{{ group.share_stock ? 'success' : 'danger' }}">{{ group.share_stock ? 'Yes' : 'No' }}</span></td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% endif %}

                    {% elseif type == 'urls' %}
                        <h4>{{ 'Shop URLs'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>
                        {% if result.urls is defined %}
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>{{ 'Name'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Domain'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'SSL Domain'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Main'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Active'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for url in result.urls %}
                                <tr>
                                    <td>{{ url.id_shop }}</td>
                                    <td>{{ url.name }}</td>
                                    <td>{{ url.domain }}</td>
                                    <td>{{ url.domain_ssl }}</td>
                                    <td><span class="badge badge-{{ url.main ? 'success' : 'secondary' }}">{{ url.main ? 'Yes' : 'No' }}</span></td>
                                    <td><span class="badge badge-{{ url.active ? 'success' : 'danger' }}">{{ url.active ? 'Yes' : 'No' }}</span></td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% endif %}

                    {% elseif type == 'images' %}
                        <h4>{{ 'Images Analysis'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>
                        <div class="row mb-4">
                            <div class="col-md-3">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Total Images'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>{{ result.total_images|default(0) }}</h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Without Images'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2 class="{{ result.products_without_images|default([])|length > 0 ? 'text-warning' : 'text-success' }}">
                                            {{ result.products_without_images|default([])|length }}
                                        </h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Without Cover'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2 class="{{ result.products_without_cover|default([])|length > 0 ? 'text-danger' : 'text-success' }}">
                                            {{ result.products_without_cover|default([])|length }}
                                        </h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Missing Shops'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2 class="{{ result.images_missing_shops|default(0) > 0 ? 'text-warning' : 'text-success' }}">
                                            {{ result.images_missing_shops|default(0) }}
                                        </h2>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {% if result.products_without_cover|default([])|length > 0 %}
                        <h5 class="mt-3">{{ 'Products Without Cover (first 20)'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                        <table class="table table-striped table-sm">
                            <thead><tr><th>ID</th><th>{{ 'Name'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th></tr></thead>
                            <tbody>
                                {% for p in result.products_without_cover %}
                                <tr><td>{{ p.id_product }}</td><td>{{ p.name }}</td></tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% endif %}

                    {% elseif type == 'cms' %}
                        <h4>{{ 'CMS Pages Analysis'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>
                        <div class="row mb-4">
                            <div class="col-md-3">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Root Category'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2 class="{{ result.root_category_exists ? 'text-success' : 'text-danger' }}">
                                            {{ result.root_category_exists ? 'OK' : 'Missing' }}
                                        </h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Total Shops'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>{{ result.total_shops|default(0) }}</h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Missing Translations'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2 class="{{ result.missing_translations|default([])|length > 0 ? 'text-warning' : 'text-success' }}">
                                            {{ result.missing_translations|default([])|length }}
                                        </h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Missing Shop Assoc'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2 class="{{ result.missing_shop_associations|default([])|length > 0 ? 'text-danger' : 'text-success' }}">
                                            {{ result.missing_shop_associations|default([])|length }}
                                        </h2>
                                    </div>
                                </div>
                            </div>
                        </div>

                    {% elseif type == 'meta' %}
                        <h4>{{ 'Meta Pages Analysis'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>
                        <div class="row mb-4">
                            <div class="col-md-3">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Total Meta Pages'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>{{ result.total_metas|default(0) }}</h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Missing Translations'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2 class="{{ result.total_missing|default(0) > 0 ? 'text-warning' : 'text-success' }}">
                                            {{ result.total_missing|default(0) }}
                                        </h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Pages With Issues'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2 class="{{ result.metas_with_issues|default([])|length > 0 ? 'text-warning' : 'text-success' }}">
                                            {{ result.metas_with_issues|default([])|length }}
                                        </h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Total Shops'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>{{ result.total_shops|default(0) }}</h2>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {% if result.metas_with_issues|default([])|length > 0 %}
                        <h5 class="mt-3">{{ 'Pages with missing translations'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                        <table class="table table-striped table-sm">
                            <thead><tr><th>ID</th><th>Page</th><th>{{ 'Existing'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th><th>{{ 'Expected'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th><th>{{ 'Missing'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th></tr></thead>
                            <tbody>
                                {% for m in result.metas_with_issues %}
                                <tr><td>{{ m.id_meta }}</td><td>{{ m.page }}</td><td>{{ m.existing }}</td><td>{{ m.expected }}</td><td class="text-warning">{{ m.missing }}</td></tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% endif %}

                    {% elseif type == 'image_shop' %}
                        <h4>{{ 'Image Shop Associations'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>

                        {# Server capabilities for image processing #}
                        {% if result.server_capabilities is defined %}
                        <div class="alert alert-{{ result.server_capabilities.webp_available ? 'success' : 'warning' }} mb-4">
                            <div class="d-flex align-items-center justify-content-between">
                                <div>
                                    <strong>
                                        <i class="material-icons" style="font-size: 18px; vertical-align: middle;">settings</i>
                                        {{ 'Server Image Capabilities'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                                    </strong>
                                    <span class="ms-3">
                                        Bibliothèque: <strong>{{ result.server_capabilities.recommended_library }}</strong>
                                    </span>
                                </div>
                                <div>
                                    {# GD Status #}
                                    <span class="badge badge-{{ result.server_capabilities.gd.installed ? (result.server_capabilities.gd.webp ? 'success' : 'warning') : 'secondary' }} me-2">
                                        GD
                                        {% if result.server_capabilities.gd.installed %}
                                            {% if result.server_capabilities.gd.webp %}
                                                + WebP
                                            {% else %}
                                                (sans WebP)
                                            {% endif %}
                                        {% else %}
                                            ❌
                                        {% endif %}
                                    </span>
                                    {# ImageMagick Status #}
                                    <span class="badge badge-{{ result.server_capabilities.imagick.installed ? (result.server_capabilities.imagick.webp ? 'success' : 'warning') : 'secondary' }}">
                                        ImageMagick
                                        {% if result.server_capabilities.imagick.installed %}
                                            {% if result.server_capabilities.imagick.webp %}
                                                + WebP
                                            {% else %}
                                                (sans WebP)
                                            {% endif %}
                                        {% else %}
                                            ❌
                                        {% endif %}
                                    </span>
                                </div>
                            </div>
                            {% if not result.server_capabilities.webp_available %}
                            <hr class="my-2">
                            <small>
                                <i class="material-icons" style="font-size: 14px; vertical-align: middle;">warning</i>
                                WebP non disponible. Activez l'extension <code>imagick</code> ou recompilez GD avec <code>--with-webp</code>.
                            </small>
                            {% endif %}
                        </div>
                        {% endif %}

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Total Images'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>{{ result.total_images|default(0) }}</h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Total Shops'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>{{ result.total_shops|default(0) }}</h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Missing Associations'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2 class="{{ result.missing_associations|default(0) > 0 ? 'text-warning' : 'text-success' }}">
                                            {{ result.missing_associations|default(0) }}
                                        </h2>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# WebP Thumbnail Coverage #}
                        {% if result.extension_stats is defined and result.extension_stats.sample_size|default(0) > 0 %}
                        {% set webpCoverage = result.extension_stats.webp_coverage_percent|default(0) %}

                        <div class="d-flex align-items-center justify-content-between mt-4 mb-3 p-3 border rounded bg-light">
                            <div>
                                <strong>{{ 'WebP Thumbnails'|trans({}, 'Modules.Scverifymultishop.Admin') }}:</strong>
                                <span class="ms-2 badge badge-{{ webpCoverage >= 100 ? 'success' : (webpCoverage >= 50 ? 'warning' : 'danger') }}" style="font-size: 1rem;">
                                    {{ webpCoverage }}%
                                </span>
                                <small class="text-muted ms-2">
                                    ({{ result.extension_stats.webp_thumbnails_sample }}/{{ result.extension_stats.expected_thumbnails_sample }} sur {{ result.extension_stats.sample_size }} images)
                                </small>
                            </div>
                            {% if webpCoverage >= 100 %}
                            <span class="text-success">
                                <i class="material-icons" style="vertical-align: middle;">check_circle</i>
                                OK
                            </span>
                            {% endif %}
                        </div>

                        {# Per-type breakdown #}
                        {% if result.extension_stats.type_stats is defined %}
                        <table class="table table-sm table-bordered mb-4">
                            <thead class="thead-light">
                                <tr>
                                    <th>{{ 'Type'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-center">{{ 'Dimensions'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-center">WebP</th>
                                    <th class="text-center">JPG</th>
                                    <th class="text-center">{{ 'Missing'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-center" style="width: 100px;">%</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for imgType in result.extension_stats.type_stats %}
                                <tr>
                                    <td><code>{{ imgType.name }}</code></td>
                                    <td class="text-center text-muted">{{ imgType.width }}×{{ imgType.height }}</td>
                                    <td class="text-center text-success">{{ imgType.webp_count }}</td>
                                    <td class="text-center">{{ imgType.jpg_count }}</td>
                                    <td class="text-center {% if imgType.missing_count > 0 %}text-danger{% endif %}">{{ imgType.missing_count }}</td>
                                    <td class="text-center">
                                        <span class="badge badge-{{ imgType.webp_percent >= 100 ? 'success' : (imgType.webp_percent >= 50 ? 'warning' : 'secondary') }}">
                                            {{ imgType.webp_percent }}%
                                        </span>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% endif %}
                        {% endif %}

                        {# Shop distribution #}
                        {% if result.shop_distribution is defined and result.shop_distribution|length > 0 %}
                        <h5 class="mt-4 mb-3">{{ 'Distribution by Shop'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                        <table class="table table-bordered table-sm">
                            <thead>
                                <tr>
                                    <th>{{ 'Shop'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-right">{{ 'Total'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-right">{{ 'Covers'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-right">{{ 'Secondary'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-right">{{ 'Missing'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-center">{{ 'Status'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for shop in result.shop_distribution %}
                                <tr>
                                    <td>
                                        <strong>{{ shop.shop_name }}</strong>
                                        <small class="text-muted">(ID: {{ shop.id_shop }})</small>
                                    </td>
                                    <td class="text-right">{{ shop.images_count }}</td>
                                    <td class="text-right">
                                        <span class="text-primary">{{ shop.covers_count }}</span>
                                    </td>
                                    <td class="text-right">
                                        <span class="text-muted">{{ shop.non_covers_count }}</span>
                                    </td>
                                    <td class="text-right">
                                        {% if shop.missing_count > 0 %}
                                            <span class="text-warning">{{ shop.missing_count }}</span>
                                        {% else %}
                                            <span class="text-success">0</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if shop.missing_count > 0 %}
                                            <span class="badge badge-warning">{{ shop.missing_count }} manquantes</span>
                                        {% elseif shop.extra_count|default(0) > 0 %}
                                            <span class="badge badge-info">{{ shop.extra_count }} orphelines</span>
                                        {% else %}
                                            <span class="badge badge-success">OK</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% endif %}

                        {% if result.missing_associations|default(0) > 0 or result.orphan_entries|default(0) > 0 %}
                        <div class="alert alert-warning">
                            <i class="material-icons">warning</i>
                            {% if result.missing_associations|default(0) > 0 %}
                                {{ 'Some images are not associated to all shops. This can cause missing images on certain storefronts.'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            {% endif %}
                            {% if result.orphan_entries|default(0) > 0 %}
                                {% if result.missing_associations|default(0) > 0 %}<br>{% endif %}
                                {{ result.orphan_entries }} entrée(s) orpheline(s) de produits inactifs à nettoyer.
                            {% endif %}
                        </div>
                        <div class="d-flex justify-content-end mt-3">
                            <a href="{{ path('sc_verify_multishop_fix_preview', {type: 'image_shop'}) }}" class="btn btn-primary">
                                <i class="material-icons">build</i>
                                {% if result.missing_associations|default(0) > 0 %}
                                    {{ 'Fix Image Associations'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                                {% else %}
                                    Nettoyer les orphelines
                                {% endif %}
                            </a>
                        </div>
                        {% else %}
                        <div class="alert alert-success">
                            <i class="material-icons">check_circle</i>
                            {{ 'All images are properly associated to all shops.'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                        </div>
                        {% endif %}

                    {% elseif type == 'duplicate_stocks' %}
                        <h4>{{ 'Stock Duplication Status'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Shop 1 Stocks'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>{{ result.count_shop1|default(0) }}</h2>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'Global Stocks (Shop 0)'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2>{{ result.count_global|default(0) }}</h2>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {% if result.needs_duplication|default(false) %}
                        <div class="alert alert-warning">
                            <i class="material-icons">warning</i>
                            {{ 'Stocks are only present in Shop 1 and need to be duplicated to the global shop (Shop 0) for proper multishop stock management.'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                        </div>
                        <div class="d-flex justify-content-end mt-3">
                            <a href="{{ path('sc_verify_multishop_fix_preview', {type: 'duplicate_stocks'}) }}" class="btn btn-primary">
                                <i class="material-icons">content_copy</i>
                                {{ 'Duplicate Stocks to All Shops'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </a>
                        </div>
                        {% else %}
                        <div class="alert alert-success">
                            <i class="material-icons">check_circle</i>
                            {{ 'Stocks are properly configured for multishop.'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                        </div>
                        {% endif %}

                    {% elseif type == 'null_quantities' %}
                        <h4>{{ 'NULL Quantities Analysis'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-body text-center">
                                        <h5>{{ 'NULL Quantities Found'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                                        <h2 class="{{ result.null_quantities|default(0) > 0 ? 'text-danger' : 'text-success' }}">
                                            {{ result.null_quantities|default(0) }}
                                        </h2>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {% if result.shop_distribution|default([])|length > 0 %}
                        <h5>{{ 'Distribution by Shop'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h5>
                        <table class="table table-striped table-sm">
                            <thead>
                                <tr>
                                    <th>{{ 'Shop ID'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'Total Entries'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th>{{ 'NULL Quantities'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for dist in result.shop_distribution %}
                                <tr>
                                    <td>{{ dist.id_shop }}</td>
                                    <td>{{ dist.count }}</td>
                                    <td>
                                        {% if dist.null_quantities > 0 %}
                                            <span class="badge badge-danger">{{ dist.null_quantities }}</span>
                                        {% else %}
                                            <span class="badge badge-success">0</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% endif %}

                        {% if result.null_quantities|default(0) > 0 %}
                        <div class="alert alert-danger mt-3">
                            <i class="material-icons">error</i>
                            {{ 'NULL quantities can cause errors in cart calculations and order processing. These should be fixed immediately.'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                        </div>
                        <div class="d-flex justify-content-end mt-3">
                            <a href="{{ path('sc_verify_multishop_fix_preview', {type: 'null_quantities'}) }}" class="btn btn-primary">
                                <i class="material-icons">build</i>
                                {{ 'Fix NULL Quantities'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </a>
                        </div>
                        {% else %}
                        <div class="alert alert-success">
                            <i class="material-icons">check_circle</i>
                            {{ 'No NULL quantities found. All stock entries have valid values.'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                        </div>
                        {% endif %}

                    {% elseif type == 'module_config' %}
                        <h4>Configuration Modules</h4>
                        <p class="text-muted">Détecte les valeurs NULL dans la configuration multishop des modules tiers.</p>

                        {% if result.modules_with_issues|default([])|length > 0 %}
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>{{ 'Module'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-center">{{ 'Issues'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for module in result.modules_with_issues %}
                                <tr>
                                    <td><code>{{ module.name }}</code></td>
                                    <td class="text-center"><span class="badge badge-warning">{{ module.issue_count }}</span></td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        <div class="d-flex justify-content-end mt-4">
                            <a href="{{ path('sc_verify_multishop_fix_preview', {type: 'module_config'}) }}" class="btn btn-primary">
                                <i class="material-icons">build</i>
                                {{ 'Fix Module Config'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </a>
                        </div>
                        {% else %}
                        <div class="alert alert-success">
                            <i class="material-icons">check_circle</i>
                            Configuration modules OK — aucun NULL bloquant détecté.
                        </div>
                        {% endif %}

                    {% elseif type == 'shop_override' %}
                        <h4>Config Shop Override</h4>
                        <p class="text-muted">Détecte les valeurs shop qui bloquent la propagation de la configuration globale.</p>

                        {% if result.modules_with_issues|default([])|length > 0 %}
                        <div class="alert alert-warning mb-4">
                            <i class="material-icons">warning</i>
                            <strong>{{ result.total_issues|default(0) }} clé(s)</strong> ont une valeur shop différente du global.
                            PrestaShop lit la valeur shop en priorité, ce qui bloque la configuration globale.
                        </div>
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>{{ 'Module'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    <th class="text-center">{{ 'Clés bloquées'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for module in result.modules_with_issues %}
                                <tr>
                                    <td><code>{{ module.name }}</code></td>
                                    <td class="text-center"><span class="badge badge-warning">{{ module.issue_count }}</span></td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        <div class="d-flex justify-content-end mt-4">
                            <a href="{{ path('sc_verify_multishop_fix_preview', {type: 'shop_override'}) }}" class="btn btn-primary">
                                <i class="material-icons">tune</i>
                                {{ 'Fix Shop Override'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </a>
                        </div>
                        {% else %}
                        <div class="alert alert-success">
                            <i class="material-icons">check_circle</i>
                            Propagation config globale OK — aucune valeur shop bloquante détectée.
                        </div>
                        {% endif %}

                    {% else %}
                        {# Generic display for unknown types #}
                        <div class="alert alert-info">
                            <i class="material-icons">info</i>
                            {{ 'Raw diagnostic data:'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                        </div>
                        <pre class="bg-light p-3 rounded">{{ result|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
                    {% endif %}

                    {# Issues display #}
                    {% if result.issues is defined and result.issues|length > 0 %}
                    <h4 class="mt-4">{{ 'Issues'|trans({}, 'Modules.Scverifymultishop.Admin') }}</h4>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>{{ 'Severity'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                <th>{{ 'Description'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                {% if result.issues[0].recommendation is defined %}
                                <th>{{ 'Recommendation'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                {% endif %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for issue in result.issues %}
                            <tr>
                                <td>
                                    <span class="badge badge-{{ issue.severity == 'error' ? 'danger' : 'warning' }}">
                                        {{ issue.severity|upper }}
                                    </span>
                                </td>
                                <td>{{ issue.description }}</td>
                                {% if issue.recommendation is defined %}
                                <td>{{ issue.recommendation }}</td>
                                {% endif %}
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                    {% endif %}
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

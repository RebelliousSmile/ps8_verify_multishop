{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
{% include '@Modules/sc_verify_multishop/views/templates/admin/_partials/header_tabs.html.twig' with {current_tab: 'dashboard', current_title: 'Preview: ' ~ type} %}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-header-title">
                    <i class="material-icons">preview</i>
                    {{ 'Preview Fix: %type%'|trans({'%type%': type}, 'Modules.Scverifymultishop.Admin') }}
                </h3>
            </div>
            <div class="card-body">
                {% if result.error is defined %}
                    <div class="alert alert-danger">
                        {{ result.error }}
                    </div>
                {% elseif result.success %}

                    {# Module list for module_config / shop_override: direct apply buttons, no dropdown #}
                    {% if type in ['module_config', 'shop_override'] and result.modules is defined and result.modules is not empty %}
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="card-header-title mb-0">
                                <i class="material-icons">tune</i>
                                {{ result.description|default('Modules à corriger') }}
                            </h5>
                        </div>
                        <div class="card-body p-0">
                            <table class="table mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>{{ 'Module'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                        <th class="text-right">{{ 'Clés à corriger'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                        <th class="text-right" style="width: 220px;">{{ 'Action'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% for mod in result.modules %}
                                <tr {% if result.selected_module == mod.name %}class="table-active"{% endif %}>
                                    <td><code>{{ mod.name }}</code></td>
                                    <td class="text-right">
                                        <span class="badge badge-warning">{{ mod.issue_count }}</span>
                                    </td>
                                    <td class="text-right">
                                        <a href="{{ path('sc_verify_multishop_fix_preview', {type: type, module: mod.name}) }}"
                                           class="btn btn-sm btn-outline-secondary mr-1">
                                            <i class="material-icons" style="font-size:14px;vertical-align:middle;">list</i>
                                            {{ 'Détails'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                                        </a>
                                        <form method="POST" action="{{ path('sc_verify_multishop_fix_apply', {type: type}) }}" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrfToken }}">
                                            <input type="hidden" name="module" value="{{ mod.name }}">
                                            <button type="submit" class="btn btn-sm btn-primary">
                                                <i class="material-icons" style="font-size:14px;vertical-align:middle;">build</i>
                                                {{ 'Appliquer'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    {% endif %}

                    {# Detail view context: show which module is being fixed #}
                    {% if result.selected_module is defined and result.selected_module and result.steps is defined %}
                    <div class="alert alert-info">
                        <i class="material-icons">tune</i>
                        {{ 'Module'|trans({}, 'Modules.Scverifymultishop.Admin') }} : <strong>{{ result.selected_module }}</strong>
                        — {{ result.description|default('') }}
                    </div>
                    {% elseif type not in ['module_config', 'shop_override'] %}
                    <div class="alert alert-info">
                        <i class="material-icons">info</i>
                        <strong>{{ result.description|default('Fix preview') }}</strong>
                    </div>
                    {% endif %}

                    {# Display general changes info #}
                    {% if result.changes is defined and result.changes is not empty %}
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="card-header-title mb-0">
                                <i class="material-icons">settings</i>
                                {{ 'Configuration'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </h5>
                        </div>
                        <div class="card-body p-0">
                            <table class="table mb-0">
                                <tbody>
                                    {% for key, value in result.changes %}
                                    <tr>
                                        <th class="w-50">{{ key|replace({'_': ' '})|title }}</th>
                                        <td>
                                            {% if value is iterable %}
                                                {% if value is empty %}
                                                    <em class="text-muted">-</em>
                                                {% else %}
                                                    <ul class="mb-0 list-unstyled">
                                                    {% for item in value %}
                                                        <li>
                                                            {% if item is iterable %}
                                                                {% for k, v in item %}
                                                                    <strong>{{ k }}:</strong> {{ v }}{% if not loop.last %}, {% endif %}
                                                                {% endfor %}
                                                            {% else %}
                                                                {{ item }}
                                                            {% endif %}
                                                        </li>
                                                    {% endfor %}
                                                    </ul>
                                                {% endif %}
                                            {% else %}
                                                <strong>{{ value }}</strong>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    {% endif %}

                    {# No occurrences found #}
                    {% if result.steps is defined and result.steps is empty and result.changes is defined and result.changes.total_rows_affected is defined and result.changes.total_rows_affected == 0 %}
                    <div class="alert alert-success">
                        <i class="material-icons">check_circle</i>
                        <strong>{{ 'Nothing to do'|trans({}, 'Modules.Scverifymultishop.Admin') }}</strong>
                        — {{ 'No occurrences found in the database. You can re-run this fix at any time after a new import.'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                    </div>
                    {% endif %}

                    {# Display detailed steps #}
                    {% if result.steps is defined and result.steps is not empty %}
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="card-header-title mb-0">
                                <i class="material-icons">list</i>
                                {{ 'Steps to execute'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </h5>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-striped mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 50px;">#</th>
                                        <th>{{ 'Table'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                        <th>{{ 'Description'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                        <th class="text-right">{{ 'Count'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                        <th class="text-center" style="width: 100px;">{{ 'Status'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for step in result.steps %}
                                    <tr>
                                        <td>
                                            <span class="badge badge-secondary">{{ step.step }}</span>
                                        </td>
                                        <td>
                                            <code>{{ step.table }}</code>
                                        </td>
                                        <td>{{ step.label }}</td>
                                        <td class="text-right">
                                            {% if step.to_update is defined and step.to_update > 0 %}
                                                <strong class="text-warning">{{ step.to_update }}</strong>
                                                <small class="text-muted">{{ 'to update'|trans({}, 'Modules.Scverifymultishop.Admin') }}</small>
                                            {% elseif step.missing is defined and step.missing > 0 %}
                                                <strong class="text-warning">{{ step.missing }}</strong>
                                                <small class="text-muted">{{ 'to create'|trans({}, 'Modules.Scverifymultishop.Admin') }}</small>
                                            {% elseif step.to_duplicate is defined and step.to_duplicate > 0 %}
                                                <strong class="text-info">{{ step.to_duplicate }}</strong>
                                                <small class="text-muted">{{ 'to duplicate'|trans({}, 'Modules.Scverifymultishop.Admin') }}</small>
                                            {% elseif step.source_count is defined %}
                                                <span class="text-muted">{{ step.source_count }} {{ 'in source'|trans({}, 'Modules.Scverifymultishop.Admin') }}</span>
                                            {% elseif step.total_products is defined %}
                                                <span class="text-muted">{{ step.total_products }} {{ 'total'|trans({}, 'Modules.Scverifymultishop.Admin') }}</span>
                                            {% elseif step.total_images is defined %}
                                                <span class="text-muted">{{ step.total_images }} {{ 'total'|trans({}, 'Modules.Scverifymultishop.Admin') }}</span>
                                            {% elseif step.total_combinations is defined %}
                                                <span class="text-muted">{{ step.total_combinations }} {{ 'total'|trans({}, 'Modules.Scverifymultishop.Admin') }}</span>
                                            {% elseif step.total_attributes is defined %}
                                                <span class="text-muted">{{ step.total_attributes }} {{ 'total'|trans({}, 'Modules.Scverifymultishop.Admin') }}</span>
                                            {% elseif step.total_categories is defined %}
                                                <span class="text-muted">{{ step.total_categories }} {{ 'total'|trans({}, 'Modules.Scverifymultishop.Admin') }}</span>
                                            {% elseif step.total_features is defined %}
                                                <span class="text-muted">{{ step.total_features }} {{ 'total'|trans({}, 'Modules.Scverifymultishop.Admin') }}</span>
                                            {% else %}
                                                <span class="text-muted">-</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-center">
                                            {% if step.status == 'ok' %}
                                                <span class="badge badge-success">
                                                    <i class="material-icons" style="font-size: 14px; vertical-align: middle;">check</i>
                                                    OK
                                                </span>
                                            {% elseif step.status == 'pending' %}
                                                <span class="badge badge-warning">
                                                    <i class="material-icons" style="font-size: 14px; vertical-align: middle;">schedule</i>
                                                    {{ 'Pending'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                                                </span>
                                            {% else %}
                                                <span class="badge badge-secondary">{{ step.status }}</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    {% endif %}

                    {# Display tables_fixed if present (legacy format) #}
                    {% if result.tables_fixed is defined and result.tables_fixed is not empty %}
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="card-header-title mb-0">
                                <i class="material-icons">storage</i>
                                {{ 'Tables to be modified'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </h5>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-striped mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>{{ 'Table'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                        <th>{{ 'Description'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for table, description in result.tables_fixed %}
                                    <tr>
                                        <td><code>{{ table }}</code></td>
                                        <td>{{ description }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    {% endif %}

                {% else %}
                    <div class="alert alert-danger">
                        {{ 'Failed to generate preview.'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                    </div>
                {% endif %}
            </div>

            {# Footer Apply button: for non-module types always; for module types only when a module is selected (detail view) — summary uses per-row buttons #}
            {% set needsModuleSelection = type in ['module_config', 'shop_override'] and not (result.selected_module is defined and result.selected_module) %}
            {% set nothingToDo = result.steps is defined and result.steps is empty and result.changes is defined and result.changes.total_rows_affected is defined and result.changes.total_rows_affected == 0 %}
            {% if result.success and not needsModuleSelection %}
            <div class="card-footer">
                <div class="d-flex justify-content-end">
                    <a href="{{ path('sc_verify_multishop_dashboard') }}" class="btn btn-outline-secondary mr-2">
                        {{ 'Cancel'|trans({}, 'Admin.Actions') }}
                    </a>
                    <form method="POST" action="{{ path('sc_verify_multishop_fix_apply', {type: type}) }}" class="d-inline" id="fix-form">
                        <input type="hidden" name="_token" value="{{ csrfToken }}">
                        {% if type in ['module_config', 'shop_override'] %}
                            <input type="hidden" name="module" value="{{ result.selected_module }}">
                        {% endif %}
                        {% if nothingToDo %}
                            <button type="button" class="btn btn-outline-success" disabled>
                                <i class="material-icons">check</i>
                                {{ 'Nothing to do'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </button>
                        {% else %}
                            {% include '@Modules/sc_verify_multishop/views/templates/admin/_partials/loading_button.html.twig' with {
                                label: 'Apply Fix',
                                loading_label: 'Processing...',
                                icon: 'build',
                                type: 'primary',
                                form_id: 'fix-form'
                            } %}
                        {% endif %}
                    </form>
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

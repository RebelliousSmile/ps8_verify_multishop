{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
{% include '@Modules/sc_verify_multishop/views/templates/admin/_partials/header_tabs.html.twig' with {current_tab: 'dashboard', current_title: 'Result: ' ~ type} %}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-header-title">
                    <i class="material-icons">{{ result.success ? 'check_circle' : 'error' }}</i>
                    {{ 'Fix Result: %type%'|trans({'%type%': type}, 'Modules.Scverifymultishop.Admin') }}
                </h3>
            </div>
            <div class="card-body">
                {% if result.success %}
                    <div class="alert alert-success">
                        <i class="material-icons">check_circle</i>
                        <strong>{{ 'Fix applied successfully!'|trans({}, 'Modules.Scverifymultishop.Admin') }}</strong>
                    </div>

                    {# Define table labels for better display #}
                    {% set tableLabels = {
                        'product_lang': 'Traductions produits',
                        'product_shop': 'Associations produit-shop',
                        'product_attribute_shop': 'Déclinaisons (combinaisons)',
                        'attribute_shop': 'Attributs',
                        'category_lang': 'Traductions catégories',
                        'category_shop': 'Associations catégorie-shop',
                        'specific_price': 'Promotions (prix spécifiques)',
                        'feature_product': 'Caractéristiques produits',
                        'feature_shop': 'Caractéristiques par shop',
                        'product_carrier': 'Transporteurs par produit',
                        'image_shop': 'Associations image-shop',
                        'carrier_shop': 'Transporteurs par shop',
                        'module_carrier': 'Modules transporteurs',
                        'delivery': 'Tarifs de livraison',
                        'carrier_zone': 'Zones transporteurs'
                    } %}

                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="card-header-title mb-0">
                                <i class="material-icons">list</i>
                                {{ 'Results'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </h5>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-striped mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>{{ 'Table'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                        <th>{{ 'Description'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                        <th class="text-center" style="width: 150px;">{{ 'Status'|trans({}, 'Modules.Scverifymultishop.Admin') }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for key, value in result %}
                                        {% if key not in ['success', 'type', 'error', 'cache_cleared', 'shops_detail', 'message', 'module'] %}
                                        <tr>
                                            <td><code>{{ key }}</code></td>
                                            <td>
                                                {{ tableLabels[key]|default(key|replace({'_': ' '})|title) }}
                                                {# Show per-shop breakdown if available #}
                                                {% if result.shops_detail[key] is defined %}
                                                <div class="small text-muted mt-1">
                                                    {% for shopId, count in result.shops_detail[key] %}
                                                        <span class="badge badge-light me-1">Shop {{ shopId }}: {{ count }}</span>
                                                    {% endfor %}
                                                </div>
                                                {% endif %}
                                            </td>
                                            <td class="text-center">
                                                {% if value is iterable %}
                                                    <span class="badge badge-info">
                                                        {{ value|length }} {{ 'items'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                                                    </span>
                                                {% elseif value is same as(true) %}
                                                    <span class="badge badge-success">
                                                        <i class="material-icons" style="font-size: 14px; vertical-align: middle;">check</i>
                                                        {{ 'Yes'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                                                    </span>
                                                {% elseif value is same as(false) %}
                                                    <span class="badge badge-danger">
                                                        <i class="material-icons" style="font-size: 14px; vertical-align: middle;">close</i>
                                                        {{ 'No'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                                                    </span>
                                                {% elseif value == 0 %}
                                                    <span class="badge badge-success">
                                                        <i class="material-icons" style="font-size: 14px; vertical-align: middle;">check</i>
                                                        {{ 'Already OK'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                                                    </span>
                                                {% elseif value > 0 %}
                                                    <span class="badge badge-primary">
                                                        <i class="material-icons" style="font-size: 14px; vertical-align: middle;">add</i>
                                                        {{ value }} {{ 'fixed'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                                                    </span>
                                                {% else %}
                                                    <span class="badge badge-secondary">{{ value }}</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                        {% endif %}
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    {# Display message if present #}
                    {% if result.message is defined %}
                    <div class="alert alert-info">
                        <i class="material-icons">info</i>
                        {{ result.message }}
                    </div>
                    {% endif %}

                    {# Summary stats #}
                    {% set totalFixed = 0 %}
                    {% set totalOk = 0 %}
                    {% for key, value in result %}
                        {% if key not in ['success', 'type', 'error', 'cache_cleared', 'shops_detail', 'message', 'module'] %}
                            {% if value is not iterable and value is not same as(true) and value is not same as(false) %}
                                {% set numValue = value matches '/^\\d+$/' ? value + 0 : 0 %}
                                {% if numValue == 0 %}
                                    {% set totalOk = totalOk + 1 %}
                                {% elseif numValue > 0 %}
                                    {% set totalFixed = totalFixed + numValue %}
                                {% endif %}
                            {% endif %}
                        {% endif %}
                    {% endfor %}

                    <div class="row">
                        <div class="col-md-6">
                            <div class="alert alert-success mb-3">
                                <i class="material-icons">check_circle</i>
                                <strong>{{ totalOk }}</strong> {{ 'table(s) already up to date'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="alert alert-primary mb-3">
                                <i class="material-icons">add_circle</i>
                                <strong>{{ totalFixed }}</strong> {{ 'row(s) created/updated'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                            </div>
                        </div>
                    </div>

                    {% if not (result.cache_cleared is defined and result.cache_cleared) %}
                    <div class="alert alert-info">
                        <i class="material-icons">info</i>
                        {{ 'Remember to clear the PrestaShop cache after applying fixes.'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                        <code class="ms-2">rm -rf var/cache/*</code>
                    </div>
                    {% endif %}
                {% else %}
                    <div class="alert alert-danger">
                        <i class="material-icons">error</i>
                        <strong>{{ 'Fix failed!'|trans({}, 'Modules.Scverifymultishop.Admin') }}</strong>
                        {% if result.error is defined %}
                            <p class="mb-0 mt-2">{{ result.error }}</p>
                        {% endif %}
                    </div>
                {% endif %}
            </div>

            <div class="card-footer">
                <div class="d-flex justify-content-end">
                    <a href="{{ path('sc_verify_multishop_dashboard') }}" class="btn btn-primary">
                        <i class="material-icons">arrow_back</i>
                        {{ 'Back to Dashboard'|trans({}, 'Modules.Scverifymultishop.Admin') }}
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
